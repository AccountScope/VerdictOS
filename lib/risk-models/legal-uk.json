{
  "industry": "legal",
  "region": "UK",
  "name": "UK Legal Services Risk Model (SRA)",
  "version": "1.0",
  "regulatory_framework": ["SRA Standards", "Legal Services Act 2007", "UK GDPR", "Solicitors Act 1974"],
  "rules": [
    {
      "id": "legal.uk.sra_conflict",
      "name": "SRA Conflict of Interest",
      "description": "Opposing party is existing client (SRA Principles)",
      "condition": {
        "field": "payload.opposing_party",
        "operator": "in_client_list",
        "value": "payload.client_list"
      },
      "risk_level": "CRITICAL",
      "action": "BLOCK",
      "requires_waiver": true,
      "regulatory_reference": "SRA Code of Conduct - Outcome 3.4 (Conflicts)"
    },
    {
      "id": "legal.uk.legal_privilege",
      "name": "Legal Professional Privilege",
      "description": "Document contains privileged communications",
      "condition": {
        "field": "payload.document_classification",
        "operator": "equals",
        "value": "legally_privileged"
      },
      "risk_level": "CRITICAL",
      "action": "REQUIRE_APPROVAL",
      "approvers": ["partner", "compliance_officer"],
      "regulatory_reference": "Common Law Legal Professional Privilege"
    },
    {
      "id": "legal.uk.limitation_act",
      "name": "Limitation Act Deadline",
      "description": "Limitation period expires within 7 days",
      "condition": {
        "field": "payload.limitation_days_remaining",
        "operator": "less_than",
        "value": 7
      },
      "risk_level": "CRITICAL",
      "action": "REQUIRE_APPROVAL",
      "approvers": ["supervising_solicitor", "partner"],
      "urgent": true,
      "regulatory_reference": "Limitation Act 1980"
    },
    {
      "id": "legal.uk.court_filing",
      "name": "Court Document Filing (CPR)",
      "description": "All court filings require solicitor review",
      "condition": {
        "field": "payload.document_type",
        "operator": "equals",
        "value": "court_filing"
      },
      "risk_level": "HIGH",
      "action": "REQUIRE_APPROVAL",
      "approvers": ["solicitor_on_record"],
      "regulatory_reference": "Civil Procedure Rules (CPR)"
    },
    {
      "id": "legal.uk.aml_client_check",
      "name": "AML Client Due Diligence",
      "description": "New client requires AML screening",
      "condition": {
        "field": "payload.client_status",
        "operator": "equals",
        "value": "prospective"
      },
      "risk_level": "MEDIUM",
      "action": "REQUIRE_APPROVAL",
      "approvers": ["mlro", "partner"],
      "regulatory_reference": "Money Laundering Regulations 2017 (MLR 2017)"
    },
    {
      "id": "legal.uk.sra_high_value",
      "name": "High-Value Matter (SRA Accounts Rules)",
      "description": "Matters over £1M require enhanced supervision",
      "condition": {
        "field": "payload.matter_value",
        "operator": "greater_than",
        "value": 1000000
      },
      "risk_level": "HIGH",
      "action": "REQUIRE_APPROVAL",
      "approvers": ["managing_partner"],
      "regulatory_reference": "SRA Accounts Rules 2019"
    },
    {
      "id": "legal.uk.gdpr_data_subject",
      "name": "UK GDPR Data Subject Rights",
      "description": "Client data access or deletion request",
      "condition": {
        "field": "payload.data_subject_request",
        "operator": "equals",
        "value": true
      },
      "risk_level": "MEDIUM",
      "action": "REQUIRE_APPROVAL",
      "approvers": ["dpo", "compliance_officer"],
      "regulatory_reference": "UK GDPR, Data Protection Act 2018"
    },
    {
      "id": "legal.uk.pii_notification",
      "name": "Professional Indemnity Insurance Notification",
      "description": "Potential claim requires PII notification",
      "condition": {
        "field": "payload.potential_claim",
        "operator": "equals",
        "value": true
      },
      "risk_level": "CRITICAL",
      "action": "REQUIRE_APPROVAL",
      "approvers": ["managing_partner", "compliance_officer"],
      "regulatory_reference": "SRA Indemnity Insurance Rules"
    }
  ],
  "scoring": {
    "LOW": {
      "range": [0, 30],
      "action": "ALLOW"
    },
    "MEDIUM": {
      "range": [31, 60],
      "action": "REQUIRE_APPROVAL"
    },
    "HIGH": {
      "range": [61, 85],
      "action": "REQUIRE_APPROVAL",
      "partner_review": true
    },
    "CRITICAL": {
      "range": [86, 100],
      "action": "BLOCK_PENDING_APPROVAL",
      "multi_authoriser": true,
      "sra_review": true
    }
  },
  "use_cases": [
    {
      "name": "SRA Conflict Screening",
      "description": "Automated conflict checks against client database, waiver management"
    },
    {
      "name": "Legal Privilege Protection",
      "description": "Privileged document classification, access control, privilege logs"
    },
    {
      "name": "Limitation Act Compliance",
      "description": "Deadline tracking, urgent escalation for expiring limitation periods"
    },
    {
      "name": "AML Compliance (UK Law Firms)",
      "description": "MLRO approval for new clients, ongoing monitoring, SAR filing"
    }
  ]
}
